/*
 * TempSense STM32H753VIT6 Thermal Sensor Board
 */

/dts-v1/;

#include <st/h7/stm32h753Xi.dtsi>
#include <st/h7/stm32h753zitx-pinctrl.dtsi>
#include <zephyr/dt-bindings/i2c/i2c.h>

 / {
	model = "TempSense STM32H753VIT6 Thermal Sensor Board";
	compatible = "st,stm32h753vi";

	chosen {
		zephyr,console = &usart3;
		zephyr,shell-uart = &usart3;

		zephyr,sram  = &sram0;
		zephyr,flash = &flash0;
		zephyr,dtcm  = &dtcm;

		zephyr,canbus = &fdcan1;
	};

	aliases {
		i2c0 = &i2c1;
		can0 = &fdcan1;
	};
};

/*
 * Clocks
 * - Your board has a 24 MHz crystal on PH0/PH1, so use HSE=24MHz (no bypass).
 * - Keep the same derived frequencies as Nucleo: SYSCLK 480 MHz, FDCAN kernel 80 MHz.
 */
&clk_hse {
	clock-frequency = <DT_FREQ_M(24)>;
	status = "okay";
};

&pll {
	/* 24MHz / 6 = 4MHz input, 4MHz * 240 = 960MHz VCO, /2 = 480MHz */
	div-m = <6>;
	mul-n = <240>;
	div-p = <2>;
	div-q = <2>;
	div-r = <2>;
	clocks = <&clk_hse>;
	status = "okay";
};

&pll2 {
	/* 24MHz / 12 = 2MHz input, 2MHz * 120 = 240MHz VCO, /3 = 80MHz for FDCAN */
	div-m = <12>;
	mul-n = <120>;
	div-p = <2>;
	div-q = <3>; /* 80MHz */
	div-r = <2>;
	clocks = <&clk_hse>;
	status = "okay";
};

&rcc {
	clocks = <&pll>;
	clock-frequency = <DT_FREQ_M(480)>;
	d1cpre = <1>;
	hpre = <2>;
	d1ppre = <2>;
	d2ppre1 = <2>;
	d2ppre2 = <2>;
	d3ppre = <2>;
};

/* Enable GPIO ports you use */
&gpioa { status = "okay"; };
&gpiob { status = "okay"; };
&gpioc { status = "okay"; };
&gpiod { status = "okay"; };
&gpioe { status = "okay"; };

/*
 * USART3 console (PD8/PD9)
 */
&usart3 {
	pinctrl-0 = <&usart3_tx_pd8 &usart3_rx_pd9>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

/*
 * CAN: transceiver RXD/TXD are on PA11/PA12 per schematic.
 * NOTE: PA11/PA12 are also commonly used for USB FS (DM/DP), so don’t enable USB FS on this pinout.
 */
&fdcan1 {
	clocks = <&rcc STM32_CLOCK_BUS_APB1_2 0x00000100>,
		 <&rcc STM32_SRC_PLL2_Q FDCAN_SEL(2)>;

	pinctrl-0 = <&fdcan1_rx_pa11 &fdcan1_tx_pa12>;
	pinctrl-names = "default";

	/* Optional but usually nice to have in DT */
	bus-speed = <500000>;

	status = "okay";
};

/*
 * I2C1: PB8/PB9 to MLX90640
 */
&i2c1 {
	pinctrl-0 = <&i2c1_scl_pb8 &i2c1_sda_pb9>;
	pinctrl-names = "default";
	clock-frequency = <I2C_BITRATE_FAST>;
	status = "okay";

	/*
	 * MLX90640 default 7-bit I2C address is 0x33 in most setups. :contentReference[oaicite:1]{index=1}
	 * Compatible string depends on the binding/driver you’re using; many Zephyr examples use "mlx90640". :contentReference[oaicite:2]{index=2}
	 */
	mlx90640: mlx90640@33 {
		compatible = "mlx90640";
		reg = <0x33>;
		label = "MLX90640";
	};
}; 